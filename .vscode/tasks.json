{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build StudentManagementSystem",
            "type": "process",
            "command": "C:\\Program Files (x86)\\MSBuild\\14.0\\Bin\\MSBuild.exe",
            "args": [
                "${workspaceFolder}\\StudentManagementSystem.sln",
                "/t:Build",
                "/p:Configuration=Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run IIS Express",
            "type": "process",
            "command": "C:\\Program Files\\IIS Express\\iisexpress.exe",
            "args": [
                "/path:${workspaceFolder}\\WebApplication5",
                "/port:52127"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Starting IIS Express ...",
                    "endsPattern": "^IIS Express is running."
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
