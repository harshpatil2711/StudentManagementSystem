# Visual Studio GitIgnore
# Recommend gitignore for .NET / C# / Visual Studio projects

## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userhtml
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/xbuild)
*.userprefs

# Mono auto generated files
*.pidb
*.resources
*.csproj.user
*.csproj.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Log]/
[L]og/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/

# MSTest test Results
[Tt]est[Rr]esults/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# ReSharper is a clean code tool for .NET developers
_ReSharper*/
*.[Re]Sharper
*.DotSettings.user

# JustCode
.JustCode

# TeamCity
_TeamCity*

# DotCover
*.dotCover

# AxoCover
.axoCover/*
!.axoCover/settings.json

# Visual Studio code database metadata
*.db
*.db-shm
*.db-wal

# EV3 Sources
*.ev3p.bak

# MyGet
myget.token

# OpenCover
OpenCover/

# ImpromptuInterface
*.ImpromptuInterface

# Crunch
Crunch.Web.xml

# Python Tools for Visual Studio
.ptvs/

# CodeKit
.codekit-cache/

# Node-gyp compilation directory
build/Release/

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
!**/packages/buildCrossTargeting/

# Feedback indicators
*.designer.cs.dll
*.designer.vb.dll

# Microsoft Fakes
FakesAssemblies/

# GhostDoc Local Rules database
*.GhostDoc.xml

# Node.js / Bower / Yeoman / Web assets
node_modules/
bower_components/
.eslintcache
.stylelintcache
*.log

# Visual Studio Server Discovery files
*.aduser

# Visual Studio history directory
.history/

# BeatPulse healthcheck indicator
healthcheck.json

# Backup folder for converting projects
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
UpgradeLog*.html

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.sbdf

# Microsoft Azure Web App publish settings. Contains sensitive information.
*.PublishSettings

# Microsoft Azure Enterprise Application patterns metadata files
*.azureactivedirectory.xml

# Azure Functions local settings
local.settings.json

# Sansar SDK build targets
Sansar.Sdk/

# Nodemon Visual Studio template
.nodemonignore

# Rider / IntelliJ IDEA
.idea/
*.sln.iml

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/gdbcommand

# WebPublish Activity log
pubxml.user

# BenchmarkDotNet outputs
BenchmarkDotNet.Artifacts/

# dotnet-dump / dotnet-gcdump exports
*.dmp
*.gcdump

# publish files
/publish/
[Pp]ublish/

# Local History for Visual Studio
.localhistory/

# Windows OS metadata
Thumbs.db
ehthumbs.db
Desktop.ini
