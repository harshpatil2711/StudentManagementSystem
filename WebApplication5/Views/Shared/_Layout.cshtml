<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Student Management System</title>

    <!-- Google Fonts - Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 CSS & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- iziToast -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/izitoast/dist/css/iziToast.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/izitoast/dist/js/iziToast.min.js"></script>

    <!-- Custom CSS -->
    @Styles.Render("~/Content/css")
    
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
</head>
<body class="min-vh-100 d-flex flex-column">

    <!-- Premium Glassmorphism Navbar -->
    <nav class="navbar navbar-expand-md navbar-light navbar-premium sticky-top">
        <div class="container-fluid max-width-lg">
            <a class="navbar-brand-premium" href="/Home/Index">
                <i class="bi bi-mortarboard-fill fs-3 text-primary"></i>
                <span>SMS Portal</span>
            </a>
            
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav gap-1 mt-2 mt-md-0">
                    <li class="nav-item">
                        <a class="nav-link nav-link-premium" href="/Home/Index">
                            <i class="bi bi-grid-1x2-fill me-1.5 opacity-75"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-premium" href="/Student/StudentInsert">
                            <i class="bi bi-person-plus-fill me-1.5 opacity-75"></i>Add Student
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-premium" href="/Home/InsertEnrollment">
                            <i class="bi bi-journal-plus me-1.5 opacity-75"></i>Add Enrollment
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-premium" href="/Home/GetList">
                            <i class="bi bi-list-columns-reverse me-1.5 opacity-75"></i>Dynamic List
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content Container -->
    <main class="flex-grow-1">
        <div class="container body-content">
            @RenderBody()
        </div>
    </main>

    <!-- Premium Footer -->
    <footer class="footer-premium text-center">
        <div class="container">
            <p class="m-0">&copy; @DateTime.Now.Year - Student Management Portal. Crafted for Excellence.</p>
        </div>
    </footer>

    @RenderSection("scripts", required: false)

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Layout JS -->
    <script src="~/Scripts/layout.js"></script>
</body>
</html>
