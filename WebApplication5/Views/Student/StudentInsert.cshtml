@model BusinessLayer.Models.Student
@{
    ViewBag.Title = "Add New Student";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10 col-12">
        <div class="form-card">
            
            <!-- Header -->
            <div class="text-center mb-4">
                <i class="bi bi-person-badge-fill text-primary" style="font-size: 3rem; background: linear-gradient(135deg, #6366f1, #4f46e5); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                <h2 class="form-title mt-2">Register Student</h2>
                <p class="text-muted">Enter student personal and academic details</p>
            </div>

            <!-- Form -->
            <div class="row">
                <!-- Student Name -->
                <div class="col-md-6 mb-3.5">
                    <label class="form-label-custom">Student Name</label>
                    <input type="text" id="StudentName" class="form-control form-control-custom" placeholder="e.g. John Doe" />
                </div>

                <!-- Date Of Birth -->
                <div class="col-md-6 mb-3.5">
                    <label class="form-label-custom">Date Of Birth</label>
                    <input type="date" id="DateOfBirth" class="form-control form-control-custom" />
                </div>

                <!-- Email -->
                <div class="col-md-6 mb-3.5 mt-3">
                    <label class="form-label-custom">Email Address</label>
                    <input type="email" id="Email" class="form-control form-control-custom" placeholder="e.g. john@example.com" />
                </div>

                <!-- Phone -->
                <div class="col-md-6 mb-3.5 mt-3">
                    <label class="form-label-custom">Phone Number</label>
                    <input type="tel" id="Phone" class="form-control form-control-custom" placeholder="e.g. +1 555-0199" />
                </div>

                <!-- Gender -->
                <div class="col-md-6 mb-3.5 mt-3">
                    <label class="form-label-custom">Gender</label>
                    <select id="Gender" class="form-select form-control-custom">
                        <option value="">Select Gender</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <!-- Admission Year -->
                <div class="col-md-6 mb-3.5 mt-3">
                    <label class="form-label-custom">Admission Year</label>
                    <select id="AdmissionYear" class="form-select form-control-custom">
                        <option value="">Select Year</option>
                    </select>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex flex-wrap gap-2.5 mt-4 pt-2 justify-content-end">
                <a href="/Home/Index" class="btn btn-premium-secondary px-4">
                    <i class="bi bi-arrow-left me-1.5"></i>Cancel
                </a>
                <button type="button" id="btnSave" class="btn btn-premium-primary px-5">
                    <i class="bi bi-check-lg me-1.5"></i>Save Student
                </button>
            </div>

            <!-- Message Notification -->
            <div id="message" class="mt-4"></div>
        </div>
    </div>
</div>

<script src="~/Scripts/studentInsert.js"></script>