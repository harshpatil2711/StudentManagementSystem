@model BusinessLayer.ViewModels.EnrollmentInsertViewModel
@{
    var isEdit = Model.EnrollmentID.HasValue && Model.EnrollmentID.Value > 0;

    ViewBag.Title = isEdit
        ? "Edit Enrollment"
        : "Add Enrollment";

    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-4">
    <div class="form-card">
        <h3 class="form-title mb-4">
            <i class="bi @(isEdit ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
            @(isEdit ? "Edit Enrollment" : "New Enrollment")
        </h3>

        <div id="message" class="mb-3"></div>

        @Html.HiddenFor(m => m.EnrollmentID,
            new { id = "EnrollmentID" })

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label-custom">Student</label>
                @Html.DropDownListFor(
                    m => m.StudentID,
                    new SelectList(Model.StudentDict,
                        "Key",
                        "Value",
                        Model.StudentID),
                    "Select Student",
                    new
                    {
                        @class = "form-control form-control-custom",
                        @id = "StudentID"
                    }
                )
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label-custom">Course Offering</label>
                @Html.DropDownListFor(
                    m => m.CourseOfferingID,
                    new SelectList(Model.CourseDict,
                        "Key",
                        "Value",
                        Model.CourseOfferingID),
                    "Select Course",
                    new
                    {
                        @class = "form-control form-control-custom",
                        @id = "CourseOfferingID"
                    }
                )
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label-custom">Enrollment Date</label>
                <input type="date"
                       id="EnrollmentDate"
                       class="form-control form-control-custom"
                       value="@(Model.EnrollmentDate.HasValue ? Model.EnrollmentDate.Value.ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label-custom">Status</label>
                @Html.DropDownListFor(
                    m => m.Status,
                    new SelectList(Model.StatusDict,
                        "Key",
                        "Value",
                        Model.Status),
                    "Select Status",
                    new
                    {
                        @class = "form-control form-control-custom",
                        @id = "Status"
                    }
                )
            </div>
        </div>

        <div class="d-flex gap-3 mt-4">
            <button type="button" id="btnSubmit" class="btn btn-submit-premium">
                <i class="bi @(isEdit ? "bi-check-lg" : "bi-plus-lg") me-2"></i>
                @(isEdit ? "Update Enrollment" : "Save Enrollment")
            </button>
            <a href="/Home/Index" class="btn btn-back">
                <i class="bi bi-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<!-- URL variables for external JS (server-side Url.Action cannot run in .js files) -->
<script>
    var insertEnrollmentUrl = '@Url.Action("InsertEnrollment", "Home")';
    var indexUrl = '@Url.Action("Index", "Home")';
</script>
<script src="~/Scripts/insertEnrollment.js"></script>
