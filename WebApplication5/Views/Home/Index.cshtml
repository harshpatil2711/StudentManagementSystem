@model BusinessLayer.ViewModels.EnrollmentViewModel
@{
    ViewBag.Title = "Enrollment List";
}

<div class="container-fluid py-4">
    <div class="main-dashboard-card">
        <!-- Header Section -->
        <div class="row align-items-center mb-4 g-3">
            <div class="col-md-6 text-center text-md-start">
                <h1 class="dashboard-title m-0">Student Enrollments</h1>
                <p class="text-muted m-0 mt-1">Manage and monitor student course registrations</p>
            </div>
            <div class="col-md-6 text-center text-md-end">
                <button id="btnAddEnrollment" class="btn btn-premium-primary">
                    <i class="bi bi-plus-lg me-2"></i>New Enrollment
                </button>
            </div>
        </div>
        <!-- Toolbar Section (Form) -->
        <form id="searchForm" method="post" class="mb-4">
            @Html.HiddenFor(m => m.page)

            <div class="row g-3 align-items-end">
                <!-- Size Selector -->
                <div class="col-12 col-sm-4 col-md-3 col-lg-2">
                    <label class="form-label-premium">Show</label>
                    @Html.DropDownListFor(
                        m => m.size,
                        new SelectList(Model.pagesizelist, Model.size),
                        new
                        {
                            @class = "form-select form-control-premium",
                            @id = "size"
                        }
                    )
                </div>

                <!-- Actions Group -->
                <div class="col-12 col-sm-8 col-md-9 col-lg-10">
                    <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-sm-end align-items-center w-100">
                        <button type="button" id="toggleFilter" class="btn btn-premium-outline flex-grow-1 flex-sm-grow-0">
                            <i class="bi bi-funnel me-1"></i>Filter
                        </button>
                        <button type="submit" class="btn btn-premium-primary flex-grow-1 flex-sm-grow-0">
                            <i class="bi bi-search me-1"></i>Search
                        </button>
                        <button type="reset" class="btn btn-premium-secondary flex-grow-1 flex-sm-grow-0">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                        </button>
                    </div>
                </div>
            </div>

            <!-- Expandable Filter Panel -->
            <div id="filterSection" class="filter-panel mt-3">
                <h5 class="fw-bold mb-3 text-secondary" style="font-size: 1rem; text-transform: uppercase; letter-spacing: 0.5px;">Advanced Filters</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label-premium">Status</label>
                        @Html.DropDownListFor(
                            m => m.status,
                            new SelectList(Model.statusDict, "Key", "Value", Model.status),
                            "-- All Statuses --",
                            new { @class = "form-select form-control-premium", @id = "status" }
                        )
                    </div>
                    <div class="col-md-5">
                        <label class="form-label-premium">Student Name</label>
                        @Html.TextBoxFor(
                            m => m.studentname,
                            new
                            {
                                @class = "form-control form-control-premium",
                                @id = "studentname",
                                placeholder = "Search student name..."
                            }
                        )
                    </div>
                </div>
            </div>
        </form>


        <!-- Error Section -->
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                <div class="fw-semibold">@ViewBag.Error</div>
            </div>
        }

        <!-- Dynamic Results Container -->
        <div id="resultContainer" class="position-relative">
            @Html.Partial("_ListData", Model)
            <div id="tableLoader" class="d-none position-absolute top-50 start-50 translate-middle text-center py-5 w-100 h-100 bg-white bg-opacity-75" style="z-index: 10;">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="mt-2 text-muted fw-semibold">Loading data...</div>
            </div>
        </div>

        <!-- Footer / Pagination Section -->
        <div class="pagination-container flex-column flex-sm-row gap-3">
            <div class="text-muted fw-semibold" id="datashown"></div>
            <div class="d-flex align-items-center gap-2">
                <button id="prevbtn" class="page-btn">
                    <i class="bi bi-chevron-left me-1"></i>Prev
                </button>
                <div id="buttonlist" class="d-inline-flex"></div>
                <button id="nextbtn" class="page-btn">
                    Next<i class="bi bi-chevron-right ms-1"></i>
                </button>
            </div>
        </div>
    </div>
</div>


<!-- Enrollment Modal -->
<div class="modal" id="enrollmentModal" tabindex="-1"
     aria-labelledby="enrollmentModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable enrollment-modal-dialog">
        <div class="modal-content enrollment-modal-content">
            <div class="modal-header enrollment-modal-header">
                <div class="enrollment-modal-title-wrap">
                    <div class="enrollment-modal-icon">
                        <i class="bi bi-journal-plus"></i>
                    </div>
                    <h5 class="modal-title" id="enrollmentModalTitle">Enrollment</h5>
                </div>
                <button type="button" class="btn-close btn-close-enrollment"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body enrollment-modal-body" id="enrollmentModalBody">
                <!-- Form content injected here by AJAX -->
            </div>
        </div>
    </div>
</div>

<!-- URL variables for external JS (server-side Url.Action cannot run in .js files) -->
<script>
    var indexActionUrl = '@Url.Action("Index", "Home")';
    var deleteEnrollmentUrl = '@Url.Action("DeleteEnrollment", "Home")';
</script>
<script src="~/Scripts/index.js"></script>
